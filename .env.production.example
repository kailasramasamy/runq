# Database
DATABASE_URL=postgresql://runq_app:STRONG_PASSWORD@localhost:5432/runq_prod

# Redis
REDIS_URL=redis://localhost:6379

# Auth — CHANGE THESE IN PRODUCTION
JWT_SECRET=generate-a-64-char-random-string
JWT_EXPIRES_IN=7d
SERVICE_JWT_SECRET=generate-another-64-char-random-string
SERVICE_JWT_EXPIRES_IN=5m

# App
PORT=3003
NODE_ENV=production

# File Storage (DO Spaces / S3)
S3_ENDPOINT=sgp1.digitaloceanspaces.com
S3_BUCKET=runq-files
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=sgp1
